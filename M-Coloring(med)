CODE WITH COMMENTS:-
class Solution:
    def graphColoring(self, v, edges, m):
        # Create adjacency list for the graph
        graph = [[] for _ in range(v)]
        for u, w in edges:
            graph[u].append(w)
            graph[w].append(u)
        
        # Array to store color of each vertex (0 means uncolored)
        c = [0] * v
        
        # Function to check if it is safe to color 'node' with 'col'
        def issafe(node, col):
            # Check all adjacent vertices
            for nei in graph[node]:
                # If any adjacent vertex has the same color, it's not safe
                if c[nei] == col:
                    return False
            return True
        
        # Backtracking function to try coloring nodes one by one
        def solve(node):
            # If all vertices are colored successfully
            if node == v:
                return True
            
            # Try all colors from 1 to m
            for col in range(1, m + 1):
                # Check if current color can be assigned
                if issafe(node, col):
                    # Assign the color
                    c[node] = col
                    
                    # Recur for the next vertex
                    if solve(node + 1):
                        return True
                    
                    # Backtrack: remove the color
                    c[node] = 0
            
            # If no color can be assigned to this node
            return False
        
        # Start coloring from vertex 0
        return solve(0)
