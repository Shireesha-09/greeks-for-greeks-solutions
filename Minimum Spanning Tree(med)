class Solution:
    def spanningTree(self, V, edges):
        par=[i for i in range(V)]
        def find(x):
            if par[x]!=x:
                par[x]=find(par[x])
            return par[x]
        def union(x,y):
            r1=find(x)
            r2=find(y)
            if r1!=r2:
                par[r1]=r2
                return True
            return False
        edges.sort(key=lambda x:x[2])
        tw=0
        for u,v,w in edges:
            if union(u,v):
                tw+=w
        return tw
