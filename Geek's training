        n = len(mat)
        
        # prev stores the maximum points till the previous day
        # Initialize it with the points from day 0
        prev = mat[0][:]
        
        # Iterate from day 1 to the last day
        for i in range(1, n):
            # curr will store the maximum points for the current day
            curr = [0, 0, 0]
            
            # If we choose activity 0 today,
            # we must choose the maximum of activities 1 or 2 from the previous day
            curr[0] = mat[i][0] + max(prev[1], prev[2])
            
            # If we choose activity 1 today,
            # we must choose the maximum of activities 0 or 2 from the previous day
